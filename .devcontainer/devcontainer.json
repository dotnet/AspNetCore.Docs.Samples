// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/dotnet
{
	"name": "C# (.NET)",
	// Or use a Dockerfile or Docker Compose file. More info: https://containers.dev/guide/dockerfile
	"image": "mcr.microsoft.com/devcontainers/dotnet:2-10.0",

	// Features to add to the dev container. More info: https://containers.dev/features.
	// Note: the dotnet devcontainer image already includes the "node" and "git" features.
	"features": {
		"ghcr.io/devcontainers/features/dotnet:2": {
			"version": "9.0",
			"additionalVersions": "8.0"
		},
		"ghcr.io/devcontainers/features/node:1": {}
	},

	// Use 'forwardPorts' to make a list of ports inside the container available locally.
	// ,"forwardPorts": []

	// Use 'postCreateCommand' to run commands after the container is created.
	// PROMPT_DIRTRIM will show only the last 1 directory in the path.
	"postCreateCommand": {
		"prompt": "echo 'export PROMPT_DIRTRIM=1' >> ~/.bashrc",
		"environment": "echo 'export ASPNETCORE_ENVIRONMENT=Development' >> ~/.bashrc",
		"dev-certs": "dotnet dev-certs https --trust",
		"gh-copilot": "npm install -g @github/copilot"
	},

	// Configure tool-specific properties.
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-dotnettools.csdevkit",
				"humao.rest-client"
			],
			"settings": {
				"dotnet.automaticallyCreateSolutionInWorkspace": false
			}
		}
	}

	// Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
	// "remoteUser": "root"
}
